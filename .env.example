# ─── J.A.R.V.I.S. v2 — Environment Variables ─────────────────────────────────
# Copy to .env for local dev. On Railway: add in service → Variables tab.

# ── PORT (Railway sets this automatically) ─────────────────────────────────────
PORT=3000

# ── GEMINI AI ──────────────────────────────────────────────────────────────────
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Click "Create API Key" → copy it here
# 3. Uses gemini-1.5-flash (fast, free tier available)

GEMINI_API_KEY=your-gemini-api-key-here

# ── GOOGLE GMAIL API ───────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create project → Enable Gmail API
# 3. OAuth consent screen → External → add your email as test user
# 4. Credentials → Create OAuth2 Client → Web Application
# 5. Authorised redirect URI: https://YOUR-RAILWAY-URL/auth/callback
# 6. Deploy → visit https://YOUR-RAILWAY-URL/auth/google → copy refresh token

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REDIRECT_URI=https://YOUR-RAILWAY-URL/auth/callback
GOOGLE_REFRESH_TOKEN=

# ── OPENWEATHERMAP ─────────────────────────────────────────────────────────────
# Free at https://openweathermap.org/api → sign up → API Keys tab

OPENWEATHER_API_KEY=your-openweather-key

# ── LOCATION (Dantewada defaults) ──────────────────────────────────────────────
WEATHER_LAT=18.8990
WEATHER_LON=81.3478
WEATHER_CITY=Dantewada
